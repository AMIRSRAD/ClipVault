{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipVault",
  "version": "0.1.0",
  "identifier": "com.clipvault.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClipVault",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "center": true
      },
      {
        "label": "palette",
        "title": "ClipVault Quick Paste",
        "width": 370,
        "height": 540,
        "resizable": false,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true,
        "backgroundColor": "#1f1f1f"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
